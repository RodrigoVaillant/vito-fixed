# Telegram — бот для получения заявок
# Создайте бота через @BotFather, получите TOKEN
# Добавьте бота в группу/чат и узнайте CHAT_ID через @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# KeyCRM — интеграция с CRM
# API ключ: KeyCRM → Настройки → API
KEYCRM_API_KEY=
# Необязательно: ID воронки и источника (смотрите в KeyCRM)
KEYCRM_PIPELINE_ID=
KEYCRM_SOURCE_ID=
